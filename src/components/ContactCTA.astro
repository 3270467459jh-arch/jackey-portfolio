---
import Icon from './Icon.astro';
---

<aside>
	<div class="contact-info">
		<p>📧 3270467459jh@gmail.com</p>
		<p>📱 15000663717（微信同号）</p>
		<p><a href="https://github.com/3270467459jh-arch" target="_blank">🔗 GitHub</a></p>
	</div>
</aside>

<style>
	aside {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		border-top: 1px solid var(--gray-800);
		border-bottom: 1px solid var(--gray-800);
		padding: 3rem 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.contact-info a {
		color: var(--accent-regular);
		text-decoration: none;
	}

	.contact-info a:hover {
		text-decoration: underline;
	}

	@media (min-width: 50em) {
		aside {
			padding: 5rem;
		}

		.contact-info {
			flex-direction: row;
			gap: 2rem;
		}
	}
</style>
