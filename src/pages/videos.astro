---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="AIGC视频作品 | Jackey-江" description="使用即梦Seedance 2.0生成的电商带货视频作品集">
	<div class="stack gap-20">
		<main class="wrapper">
			<Hero
				title="AIGC视频作品"
				tagline="使用即梦 Seedance 2.0 生成的电商带货视频，覆盖产品展示、使用演示、场景化等多种风格。"
			/>

			<div class="video-intro">
				<p>以下视频均由AI生成，用于TikTok/独立站投放素材测试。通过精心设计的提示词模板，实现批量产出多风格电商视频，月产60+条。</p>
			</div>

			<div class="video-grid">
				{Array.from({ length: 11 }, (_, i) => i + 1).map((page) => (
					<div class="video-item">
						<iframe
							src={`//player.bilibili.com/player.html?bvid=BV1KgVs6SEvM&page=${page}&high_quality=1&danmaku=0`}
							allowfullscreen
							frameborder="0"
							scrolling="no"
						></iframe>
					</div>
				))}
			</div>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.video-intro {
		max-width: 65ch;
		margin: 0 auto;
		text-align: center;
		font-size: var(--text-md);
		color: var(--gray-300);
		margin-bottom: 2rem;
	}

	.video-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	.video-item {
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-md);
		background: var(--gray-800);
		aspect-ratio: 16 / 9;
	}

	.video-item iframe {
		width: 100%;
		height: 100%;
		border: none;
	}

	@media (min-width: 50em) {
		.video-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (min-width: 72em) {
		.video-grid {
			grid-template-columns: 1fr 1fr 1fr;
		}
	}
</style>
